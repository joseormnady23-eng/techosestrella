APP_NAME=Klika
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Santo_Domingo

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_DO

LOG_CHANNEL=stack
LOG_LEVEL=warning

# La conexión de BD la inyecta docker-compose (DB_HOST=db, etc.).
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=klika
DB_USERNAME=klika
DB_PASSWORD=klika_secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

FILESYSTEM_DISK=public

# --- Klika / integraciones ---
KLIKA_OLLAMA_URL=http://10.0.0.237:11434
KLIKA_OLLAMA_MODEL=klika:latest
KLIKA_OLLAMA_TIMEOUT=120
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
DGII_ECF_ENV=testecf
DGII_ECF_BASE_URL=https://ecf.dgii.gov.do/testecf/
# DGII_ECF_CERT_PATH=/var/www/html/storage/app/cert.p12
